{
  "ConnectionStrings": {
    "TaskReminder": "Host=YOUR_POSTGRES_HOST;Port=5432;Database=task_reminder;Username=YOUR_USERNAME;Password=YOUR_PASSWORD"
  },
  "App": {
    "RunMigrationsOnStartup": true,
    "SeedDemoDataOnStartup": false
  },
  "Deployment": {
    "MinimumSupportedDesktopVersion": "1.0.0",
    "RecommendedDesktopVersion": "1.0.0",
    "EnableAudit": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "File": {
      "Enabled": true,
      "Path": "%LOCALAPPDATA%\\Task_Reminder\\Logs\\api\\task-reminder-api.log",
      "MinimumLevel": "Information",
      "RollDaily": true,
      "RetainedFileCountLimit": 14
    }
  },
  "AllowedHosts": "*"
}
