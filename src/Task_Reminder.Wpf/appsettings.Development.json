{
  "Client": {
    "ApiBaseUrl": "https://localhost:7087/",
    "SignalRHubUrl": "https://localhost:7087/hubs/tasks",
    "ReminderPollingSeconds": 30,
    "DefaultRepeatMinutes": 15,
    "AllowInvalidLocalCertificatesInDevelopment": true
  },
  "Logging": {
    "File": {
      "Enabled": true,
      "Path": "%LOCALAPPDATA%\\Task_Reminder\\Logs\\wpf\\task-reminder-wpf.dev.log",
      "MinimumLevel": "Debug",
      "RollDaily": true,
      "RetainedFileCountLimit": 14
    }
  }
}
