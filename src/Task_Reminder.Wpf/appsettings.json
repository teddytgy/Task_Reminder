{
  "Client": {
    "ApiBaseUrl": "https://YOUR-API-HOSTNAME-OR-IP:7087/",
    "SignalRHubUrl": "https://YOUR-API-HOSTNAME-OR-IP:7087/hubs/tasks",
    "ReminderPollingSeconds": 60,
    "DefaultRepeatMinutes": 30,
    "AllowInvalidLocalCertificatesInDevelopment": false
  },
  "Logging": {
    "File": {
      "Enabled": true,
      "Path": "%LOCALAPPDATA%\\Task_Reminder\\Logs\\wpf\\task-reminder-wpf.log",
      "MinimumLevel": "Information",
      "RollDaily": true,
      "RetainedFileCountLimit": 14
    }
  }
}
