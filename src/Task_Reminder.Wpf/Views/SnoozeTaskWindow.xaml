<Window x:Class="Task_Reminder.Wpf.Views.SnoozeTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Snooze Task"
        Height="180"
        Width="360"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBox Height="36" Text="{Binding SnoozeUntilLocalText}" ToolTip="Use local time, for example 2026-03-12 15:00" />

        <StackPanel Grid.Row="1" Margin="0,16,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="90" Margin="0,0,8,0" Content="Cancel" Click="Cancel_Click" />
            <Button Width="90" Content="Snooze" Click="Snooze_Click" />
        </StackPanel>
    </Grid>
</Window>
