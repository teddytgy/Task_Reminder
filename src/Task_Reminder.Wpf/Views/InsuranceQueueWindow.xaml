<Window x:Class="Task_Reminder.Wpf.Views.InsuranceQueueWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Insurance Queue"
        Height="720"
        Width="1180"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.7*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,12">
            <ComboBox Width="220" ItemsSource="{Binding Filters}" SelectedItem="{Binding SelectedFilter}" />
            <Button Width="90" Margin="8,0,0,0" Content="Refresh" Command="{Binding RefreshCommand}" />
            <Button Width="90" Margin="8,0,0,0" Content="Started" Command="{Binding MarkStartedCommand}" />
            <Button Width="90" Margin="8,0,0,0" Content="Verified" Command="{Binding MarkVerifiedCommand}" />
            <Button Width="90" Margin="8,0,0,0" Content="Failed" Command="{Binding MarkFailedCommand}" />
            <Button Width="120" Margin="8,0,0,0" Content="Manual Review" Command="{Binding MarkManualReviewCommand}" />
            <Button Width="120" Margin="8,0,0,0" Content="Inactive Coverage" Command="{Binding MarkInactiveCoverageCommand}" />
        </StackPanel>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Items}"
                  SelectedItem="{Binding SelectedItem}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Patient" Binding="{Binding PatientName}" Width="2*" />
                <DataGridTextColumn Header="Carrier" Binding="{Binding CarrierName}" Width="*" />
                <DataGridTextColumn Header="Appt Date" Binding="{Binding AppointmentDateLocal}" Width="*" />
                <DataGridTextColumn Header="Verification" Binding="{Binding VerificationStatus}" Width="*" />
                <DataGridTextColumn Header="Eligibility" Binding="{Binding EligibilityStatus}" Width="*" />
                <DataGridTextColumn Header="Issue" Binding="{Binding IssueType}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Grid.Column="1" Margin="16,0,0,0">
            <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding SelectedItem.PatientName}" />
            <TextBlock Margin="0,8,0,0" Text="{Binding SelectedItem.PlanName, StringFormat=Plan: {0}}" />
            <TextBlock Margin="0,8,0,0" Text="{Binding SelectedItem.MemberId, StringFormat=Member ID: {0}}" />
            <TextBlock Margin="0,8,0,0" Text="{Binding SelectedItem.LatestContactSummary, StringFormat=Latest Contact: {0}}" />
            <Button Margin="0,16,0,0" Content="Add Contact Log" Command="{Binding AddContactLogCommand}" />
            <Button Margin="0,8,0,0" Content="Create Patient Follow-Up Task" Command="{Binding CreateFollowUpTaskCommand}" />
            <Button Margin="0,8,0,0" Content="Create Manager Task" Command="{Binding CreateManagerTaskCommand}" />
            <GroupBox Margin="0,16,0,0" Header="Contact Timeline">
                <DataGrid ItemsSource="{Binding ContactLogs}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="When" Binding="{Binding PerformedAtUtc, Converter={StaticResource UtcToLocalDateTimeConverter}}" Width="*" />
                        <DataGridTextColumn Header="Type" Binding="{Binding ContactType}" Width="*" />
                        <DataGridTextColumn Header="Outcome" Binding="{Binding Outcome}" Width="*" />
                        <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="2*" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
            <TextBlock Margin="0,12,0,0" Foreground="#666" Text="{Binding StatusMessage}" />
        </StackPanel>
    </Grid>
</Window>
