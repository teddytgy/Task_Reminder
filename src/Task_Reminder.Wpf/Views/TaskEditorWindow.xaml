<Window x:Class="Task_Reminder.Wpf.Views.TaskEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Task"
        Height="520"
        Width="520"
        WindowStartupLocation="CenterOwner">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="Title" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Margin="8,0,0,12" Text="{Binding Title}" />

            <TextBlock Grid.Row="1" Text="Description" VerticalAlignment="Top" />
            <TextBox Grid.Row="1" Grid.Column="1" Margin="8,0,0,12" Height="72" AcceptsReturn="True" TextWrapping="Wrap" Text="{Binding Description}" />

            <TextBlock Grid.Row="2" Text="Category" VerticalAlignment="Center" />
            <ComboBox Grid.Row="2" Grid.Column="1" Margin="8,0,0,12" ItemsSource="{Binding Categories}" SelectedItem="{Binding Category}" />

            <TextBlock Grid.Row="3" Text="Priority" VerticalAlignment="Center" />
            <ComboBox Grid.Row="3" Grid.Column="1" Margin="8,0,0,12" ItemsSource="{Binding Priorities}" SelectedItem="{Binding Priority}" />

            <TextBlock Grid.Row="4" Text="Due At" VerticalAlignment="Center" />
            <TextBox Grid.Row="4" Grid.Column="1" Margin="8,0,0,12" Text="{Binding DueAtLocalText}" ToolTip="Use local time, for example 2026-03-12 14:30" />

            <TextBlock Grid.Row="5" Text="Patient Ref" VerticalAlignment="Center" />
            <TextBox Grid.Row="5" Grid.Column="1" Margin="8,0,0,12" Text="{Binding PatientReference}" />

            <TextBlock Grid.Row="6" Text="Repeat Minutes" VerticalAlignment="Center" />
            <TextBox Grid.Row="6" Grid.Column="1" Margin="8,0,0,12" Text="{Binding ReminderRepeatMinutes}" />

            <TextBlock Grid.Row="7" Text="Notes" VerticalAlignment="Top" />
            <TextBox Grid.Row="7" Grid.Column="1" Margin="8,0,0,12" Height="72" AcceptsReturn="True" TextWrapping="Wrap" Text="{Binding Notes}" />

            <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Width="90" Margin="0,8,8,0" Content="Cancel" Click="Cancel_Click" />
                <Button Width="90" Margin="0,8,0,0" Content="Create" Click="Create_Click" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
