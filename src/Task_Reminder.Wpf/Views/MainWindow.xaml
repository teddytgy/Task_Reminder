<Window x:Class="Task_Reminder.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Reminder Dashboard"
        Height="760"
        Width="1320"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <DockPanel Grid.ColumnSpan="2">
            <TextBlock FontSize="26" FontWeight="SemiBold" Text="Front Desk Shared Tasks" />
            <TextBlock Margin="16,8,0,0" VerticalAlignment="Center" Foreground="#555" Text="{Binding CurrentUserDisplayName}" />
        </DockPanel>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,16,0,16" Orientation="Horizontal">
            <ComboBox Width="200"
                      ItemsSource="{Binding Filters}"
                      DisplayMemberPath="DisplayName"
                      SelectedItem="{Binding SelectedFilter}" />
            <Button Width="100" Margin="12,0,0,0" Content="New Task" Command="{Binding NewTaskCommand}" />
            <Button Width="90" Margin="8,0,0,0" Content="Assign" Command="{Binding AssignCommand}" />
            <Button Width="90" Margin="8,0,0,0" Content="Claim" Command="{Binding ClaimCommand}" />
            <Button Width="90" Margin="8,0,0,0" Content="Snooze" Command="{Binding SnoozeCommand}" />
            <Button Width="90" Margin="8,0,0,0" Content="Complete" Command="{Binding CompleteCommand}" />
            <Button Width="90" Margin="8,0,0,0" Content="Refresh" Command="{Binding RefreshCommand}" />
            <TextBlock Margin="16,8,0,0" Foreground="#666" Text="{Binding StatusMessage}" />
        </StackPanel>

        <Border Grid.Row="2" Grid.Column="0" Padding="12" BorderBrush="#DDD" BorderThickness="1" CornerRadius="8">
            <DataGrid ItemsSource="{Binding Tasks}"
                      SelectedItem="{Binding SelectedTask}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                <Setter Property="Background" Value="#FFF2D9D9" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="2*" />
                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="*" />
                    <DataGridTextColumn Header="Priority" Binding="{Binding Priority}" Width="*" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" />
                    <DataGridTextColumn Header="Assigned" Binding="{Binding AssignedUserDisplayName}" Width="*" />
                    <DataGridTextColumn Header="Working" Binding="{Binding ClaimedByDisplayName}" Width="*" />
                    <DataGridTextColumn Header="Due" Binding="{Binding DueAtUtc, Converter={StaticResource UtcToLocalDateTimeConverter}}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="2" Grid.Column="1" Margin="16,0,0,0" Padding="16" BorderBrush="#DDD" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="2*" />
                </Grid.RowDefinitions>

                <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding SelectedTask.Title}" />
                <TextBlock Grid.Row="1" Margin="0,12,0,0" Text="{Binding SelectedTask.Description}" TextWrapping="Wrap" />
                <TextBlock Grid.Row="2" Margin="0,12,0,0" Text="{Binding SelectedTask.PatientReference, StringFormat=Patient: {0}}" />
                <TextBlock Grid.Row="3" Margin="0,8,0,0" Text="{Binding SelectedTask.AssignedUserDisplayName, StringFormat=Assigned To: {0}}" />
                <TextBlock Grid.Row="4" Margin="0,8,0,0" Text="{Binding SelectedTask.ClaimedByDisplayName, StringFormat=Currently Working: {0}}" />

                <GroupBox Grid.Row="5" Margin="0,16,0,0" Header="Notes">
                    <TextBlock Padding="8" TextWrapping="Wrap" Text="{Binding SelectedTask.Notes}" />
                </GroupBox>

                <GroupBox Grid.Row="6" Margin="0,16,0,0" Header="Audit History">
                    <DataGrid ItemsSource="{Binding TaskHistory}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="When" Binding="{Binding PerformedAtUtc, Converter={StaticResource UtcToLocalDateTimeConverter}}" Width="*" />
                            <DataGridTextColumn Header="Action" Binding="{Binding ActionType}" Width="*" />
                            <DataGridTextColumn Header="By" Binding="{Binding PerformedByDisplayName}" Width="*" />
                            <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
            </Grid>
        </Border>
    </Grid>
</Window>
