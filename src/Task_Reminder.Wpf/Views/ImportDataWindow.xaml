<Window x:Class="Task_Reminder.Wpf.Views.ImportDataWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import Data"
        Height="520"
        Width="700"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal">
            <ComboBox Width="160" ItemsSource="{Binding Modules}" SelectedItem="{Binding Module}" />
            <ComboBox Width="120" Margin="8,0,0,0" ItemsSource="{Binding Formats}" SelectedItem="{Binding Format}" />
            <TextBox Width="160" Margin="8,0,0,0" Text="{Binding SourceSystem}" />
            <Button Width="90" Margin="8,0,0,0" Content="Import" Command="{Binding ImportCommand}" />
        </StackPanel>
        <TextBox Grid.Row="1" Margin="0,12,0,12" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" Text="{Binding Content}" />
        <TextBlock Grid.Row="2" Foreground="#666" Text="{Binding StatusMessage}" />
    </Grid>
</Window>
