<Window x:Class="Task_Reminder.Wpf.Views.NotificationSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="My Notification Settings"
        Height="360"
        Width="460"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="22" FontWeight="SemiBold" Text="Reminder Preferences" />
        <CheckBox Grid.Row="1" Margin="0,16,0,0" Content="Receive reminders for tasks assigned to me" IsChecked="{Binding ReceiveAssignedTaskReminders}" />
        <CheckBox Grid.Row="2" Margin="0,12,0,0" Content="Receive reminders for unassigned front desk tasks" IsChecked="{Binding ReceiveUnassignedTaskReminders}" />
        <CheckBox Grid.Row="3" Margin="0,12,0,0" Content="Receive overdue escalation alerts" IsChecked="{Binding ReceiveOverdueEscalationAlerts}" />
        <CheckBox Grid.Row="4" Margin="0,12,0,0" Content="Receive recurring task generation alerts" IsChecked="{Binding ReceiveRecurringTaskGenerationAlerts}" />
        <CheckBox Grid.Row="5" Margin="0,12,0,0" Content="Play a sound for urgent reminders" IsChecked="{Binding EnableSoundForUrgentReminders}" VerticalAlignment="Top" />

        <DockPanel Grid.Row="6" Margin="0,18,0,0">
            <TextBlock VerticalAlignment="Center" Foreground="#666" Text="{Binding StatusMessage}" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                <Button Width="90" Margin="0,0,8,0" Content="Cancel" Click="Cancel_Click" />
                <Button Width="90" Content="Save" Command="{Binding SaveCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
