<Window x:Class="Task_Reminder.Wpf.Views.RecurringTasksWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recurring Task Templates"
        Height="720"
        Width="1180"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.1*" />
            <ColumnDefinition Width="1.9*" />
        </Grid.ColumnDefinitions>

        <GroupBox Header="Templates" Margin="0,0,16,0">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,12">
                    <Button Width="90" Content="New" Command="{Binding NewDefinitionCommand}" />
                    <Button Width="90" Margin="8,0,0,0" Content="Delete" Command="{Binding DeleteCommand}" />
                    <Button Width="110" Margin="8,0,0,0" Content="Enable/Disable" Command="{Binding ToggleActiveCommand}" />
                </StackPanel>

                <DataGrid ItemsSource="{Binding Definitions}"
                          SelectedItem="{Binding SelectedDefinition}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="2*" />
                        <DataGridTextColumn Header="Pattern" Binding="{Binding RecurrenceType}" Width="*" />
                        <DataGridTextColumn Header="Assigned" Binding="{Binding AssignedUserDisplayName}" Width="*" />
                        <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </GroupBox>

        <GroupBox Grid.Column="1" Header="Recurring Task Details">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Title" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1" Margin="8,0,0,12" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="1" Text="Description" VerticalAlignment="Top" />
                    <TextBox Grid.Row="1" Grid.Column="1" Margin="8,0,0,12" Height="64" AcceptsReturn="True" TextWrapping="Wrap" Text="{Binding Description}" />

                    <TextBlock Grid.Row="2" Text="Category" VerticalAlignment="Center" />
                    <ComboBox Grid.Row="2" Grid.Column="1" Margin="8,0,0,12" ItemsSource="{Binding Categories}" SelectedItem="{Binding Category}" />

                    <TextBlock Grid.Row="3" Text="Priority" VerticalAlignment="Center" />
                    <ComboBox Grid.Row="3" Grid.Column="1" Margin="8,0,0,12" ItemsSource="{Binding Priorities}" SelectedItem="{Binding Priority}" />

                    <TextBlock Grid.Row="4" Text="Assigned User" VerticalAlignment="Center" />
                    <ComboBox Grid.Row="4" Grid.Column="1" Margin="8,0,0,12" ItemsSource="{Binding Users}" DisplayMemberPath="DisplayName" SelectedItem="{Binding SelectedAssignedUser}" />

                    <TextBlock Grid.Row="5" Text="Escalate To" VerticalAlignment="Center" />
                    <ComboBox Grid.Row="5" Grid.Column="1" Margin="8,0,0,12" ItemsSource="{Binding Users}" DisplayMemberPath="DisplayName" SelectedItem="{Binding SelectedEscalateToUser}" />

                    <TextBlock Grid.Row="6" Text="Patient Ref" VerticalAlignment="Center" />
                    <TextBox Grid.Row="6" Grid.Column="1" Margin="8,0,0,12" Text="{Binding PatientReference}" />

                    <TextBlock Grid.Row="7" Text="Notes / Checklist" VerticalAlignment="Top" />
                    <TextBox Grid.Row="7" Grid.Column="1" Margin="8,0,0,12" Height="72" AcceptsReturn="True" TextWrapping="Wrap" Text="{Binding Notes}" />

                    <TextBlock Grid.Row="8" Text="Repeat Minutes" VerticalAlignment="Center" />
                    <TextBox Grid.Row="8" Grid.Column="1" Margin="8,0,0,12" Text="{Binding ReminderRepeatMinutes}" />

                    <TextBlock Grid.Row="9" Text="Escalate After Min" VerticalAlignment="Center" />
                    <TextBox Grid.Row="9" Grid.Column="1" Margin="8,0,0,12" Text="{Binding EscalateAfterMinutes}" />

                    <TextBlock Grid.Row="10" Text="Recurrence Type" VerticalAlignment="Center" />
                    <ComboBox Grid.Row="10" Grid.Column="1" Margin="8,0,0,12" ItemsSource="{Binding RecurrenceTypes}" SelectedItem="{Binding RecurrenceType}" />

                    <TextBlock Grid.Row="11" Text="Interval / Days / DOM" VerticalAlignment="Center" />
                    <StackPanel Grid.Row="11" Grid.Column="1" Margin="8,0,0,12" Orientation="Horizontal">
                        <TextBox Width="80" Text="{Binding RecurrenceInterval}" ToolTip="Interval" />
                        <TextBox Width="220" Margin="8,0,0,0" Text="{Binding DaysOfWeek}" ToolTip="For weekly: Monday,Wednesday,Friday" />
                        <TextBox Width="80" Margin="8,0,0,0" Text="{Binding DayOfMonth}" ToolTip="For monthly" />
                    </StackPanel>

                    <TextBlock Grid.Row="12" Text="Time / Start / End" VerticalAlignment="Center" />
                    <StackPanel Grid.Row="12" Grid.Column="1" Margin="8,0,0,12" Orientation="Horizontal">
                        <TextBox Width="90" Text="{Binding TimeOfDayLocalText}" ToolTip="hh:mm" />
                        <TextBox Width="120" Margin="8,0,0,0" Text="{Binding StartDateLocalText}" ToolTip="yyyy-MM-dd" />
                        <TextBox Width="120" Margin="8,0,0,0" Text="{Binding EndDateLocalText}" ToolTip="yyyy-MM-dd" />
                    </StackPanel>

                    <CheckBox Grid.Row="13" Grid.ColumnSpan="2" Margin="0,8,0,0" Content="Active" IsChecked="{Binding IsActive}" VerticalAlignment="Top" />

                    <DockPanel Grid.Row="14" Grid.ColumnSpan="2" Margin="0,18,0,0">
                        <TextBlock VerticalAlignment="Center" Foreground="#666" Text="{Binding StatusMessage}" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Width="90" Margin="0,0,8,0" Content="Close" Click="Close_Click" />
                            <Button Width="90" Content="Save" Command="{Binding SaveCommand}" />
                        </StackPanel>
                    </DockPanel>
                </Grid>
            </ScrollViewer>
        </GroupBox>
    </Grid>
</Window>
