<Window x:Class="Task_Reminder.Wpf.Views.AdminOperationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Admin Operations"
        Height="720"
        Width="1180"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <TextBlock FontSize="24" FontWeight="SemiBold" Text="Admin Operations" />
            <Button Width="90" Margin="20,0,0,0" Content="Refresh" Command="{Binding RefreshCommand}" />
            <Button Width="120" Margin="8,0,0,0" Content="Run Integration" Command="{Binding RunIntegrationCommand}" />
            <TextBlock Margin="16,6,0,0" Foreground="#666" Text="{Binding StatusMessage}" />
        </StackPanel>

        <Border Grid.Row="1" Margin="0,16,0,16" Padding="12" BorderBrush="#DDD" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="Office" />
                    <TextBlock Margin="0,8,0,0" Text="{Binding SystemSummary.OfficeName}" />
                    <TextBlock Margin="0,4,0,0" Text="{Binding SystemSummary.VersionInfo.ApiVersion, StringFormat=API Version: {0}}" />
                    <TextBlock Margin="0,4,0,0" Text="{Binding SystemSummary.VersionInfo.RecommendedDesktopVersion, StringFormat=Recommended Desktop: {0}}" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock FontWeight="SemiBold" Text="Runtime" />
                    <TextBlock Margin="0,8,0,0" Text="{Binding SystemSummary.HealthUrl, StringFormat=Health: {0}}" />
                    <TextBlock Margin="0,4,0,0" Text="{Binding SystemSummary.SignalRHubPath, StringFormat=SignalR: {0}}" />
                    <TextBlock Margin="0,4,0,0" Text="{Binding SystemSummary.LogPath, StringFormat=Logs: {0}}" TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock FontWeight="SemiBold" Text="Deployment Notes" />
                    <TextBlock Margin="0,8,0,0" Text="{Binding SystemSummary.RunMigrationsOnStartup, StringFormat=Run Migrations: {0}}" />
                    <TextBlock Margin="0,4,0,0" Text="{Binding SystemSummary.SeedDemoDataOnStartup, StringFormat=Seed Demo Data: {0}}" />
                    <TextBlock Margin="0,4,0,0" Text="{Binding SystemSummary.AuditEnabled, StringFormat=Audit Enabled: {0}}" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="2">
            <TabItem Header="Audit">
                <DataGrid ItemsSource="{Binding AuditEntries}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="When" Binding="{Binding PerformedAtUtc}" Width="*" />
                        <DataGridTextColumn Header="User" Binding="{Binding PerformedByDisplayName}" Width="*" />
                        <DataGridTextColumn Header="Entity" Binding="{Binding EntityType}" Width="*" />
                        <DataGridTextColumn Header="Action" Binding="{Binding ActionType}" Width="*" />
                        <DataGridTextColumn Header="Summary" Binding="{Binding Summary}" Width="2*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Integrations">
                <DataGrid ItemsSource="{Binding Integrations}" SelectedItem="{Binding SelectedIntegration}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Provider" Binding="{Binding DisplayName}" Width="2*" />
                        <DataGridTextColumn Header="Enabled" Binding="{Binding IsEnabled}" Width="*" />
                        <DataGridTextColumn Header="Last Status" Binding="{Binding LastRunStatus}" Width="*" />
                        <DataGridTextColumn Header="Last Run" Binding="{Binding LastRunCompletedAtUtc}" Width="*" />
                        <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="2*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
